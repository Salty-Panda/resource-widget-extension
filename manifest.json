{
  "manifest_version": 3,
  "name": "Resource ID Manager",
  "short_name": "RIM",
  "version": "1.0.0",
  "description": "ID-driven resource management system — consolidate URLs, manage IDs, recover broken links.",
  "permissions": [
    "storage",
    "bookmarks",
    "tabs",
    "activeTab",
    "scripting",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Resource ID Manager"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}